{
  "name": "apex-doctor",
  "displayName": "Apex Doctor",
  "description": "Diagnose Salesforce Apex debug logs in seconds. AI root-cause analysis, performance insights, live log streaming, SOQL-in-loop detection, activity timeline, and one-click navigation to Apex source.",
  "version": "0.12.5",
  "publisher": "amanparate",
  "author": {
    "name": "Aman Parate",
    "url": "https://github.com/amanparate"
  },
  "license": "MIT",
  "icon": "images/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/amanparate/apex-doctor.git"
  },
  "bugs": {
    "url": "https://github.com/amanparate/apex-doctor/issues"
  },
  "homepage": "https://github.com/amanparate/apex-doctor#readme",
  "galleryBanner": {
    "color": "#032E61",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.116.0"
  },
  "categories": [
    "Other",
    "Visualization"
  ],
  "keywords": [
    "salesforce",
    "apex",
    "sfdx",
    "debug log",
    "log analyzer",
    "ai",
    "claude",
    "openrouter",
    "performance",
    "soql"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "apexDoctor.analyze",
        "title": "Analyse this Apex Log",
        "category": "Apex Doctor"
      },
      {
        "command": "apexDoctor.fetchLog",
        "title": "Fetch Log from Salesforce",
        "category": "Apex Doctor"
      },
      {
        "command": "apexDoctor.exportMarkdown",
        "title": "Export Analysis as Markdown",
        "category": "Apex Doctor"
      },
      {
        "command": "apexDoctor.setApiKey",
        "title": "Set LLM API Key",
        "category": "Apex Doctor"
      },
      {
        "command": "apexDoctor.startStream",
        "title": "Start Log Streaming",
        "category": "Apex Doctor"
      },
      {
        "command": "apexDoctor.stopStream",
        "title": "Stop Log Streaming",
        "category": "Apex Doctor"
      },
      {
        "command": "apexDoctor.compareLogs",
        "title": "Compare Two Apex Logs",
        "category": "Apex Doctor"
      },
      {
        "command": "apexDoctor.clearApiKey",
        "title": "Clear LLM API Key",
        "category": "Apex Doctor"
      },
      {
        "command": "apexDoctor.openRecent",
        "title": "Open Recent Analysis",
        "category": "Apex Doctor"
      },
      {
        "command": "apexDoctor.clearRecent",
        "title": "Clear Recent Analyses",
        "category": "Apex Doctor",
        "icon": "$(clear-all)"
      },
      {
        "command": "apexDoctor.removeRecent",
        "title": "Remove from Recent",
        "category": "Apex Doctor",
        "icon": "$(close)"
      },
      {
        "command": "apexDoctor.manageTraceFlags",
        "title": "Manage Trace Flags",
        "category": "Apex Doctor"
      },
      {
        "command": "apexDoctor.refreshCoverage",
        "title": "Refresh Test Coverage",
        "category": "Apex Doctor"
      },
      {
        "command": "apexDoctor.toggleCoverage",
        "title": "Toggle Coverage Overlay",
        "category": "Apex Doctor"
      },
      {
        "command": "apexDoctor.queryPlan",
        "title": "Run SOQL Query Plan…",
        "category": "Apex Doctor"
      },
      {
        "command": "apexDoctor.openAnonymousEditor",
        "title": "Open Anonymous Apex Editor",
        "category": "Apex Doctor"
      },
      {
        "command": "apexDoctor.runAnonymousApex",
        "title": "Run This Anonymous Apex",
        "category": "Apex Doctor"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "apexDoctor",
          "title": "Apex Doctor",
          "icon": "images/sidebar-icon.svg"
        }
      ]
    },
    "views": {
      "apexDoctor": [
        {
          "id": "apexDoctor.currentAnalysis",
          "name": "Current Analysis"
        },
        {
          "id": "apexDoctor.recent",
          "name": "Recent Logs"
        },
        {
          "id": "apexDoctor.recurring",
          "name": "Recurring Issues"
        }
      ]
    },
    "keybindings": [
      {
        "command": "apexDoctor.analyze",
        "key": "ctrl+alt+a",
        "mac": "cmd+alt+a",
        "when": "editorTextFocus"
      },
      {
        "command": "apexDoctor.fetchLog",
        "key": "ctrl+alt+f",
        "mac": "cmd+alt+f"
      },
      {
        "command": "apexDoctor.manageTraceFlags",
        "key": "ctrl+alt+t",
        "mac": "cmd+alt+t"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "apexDoctor.analyze",
          "group": "1_apexDoctor@1"
        }
      ],
      "view/title": [
        {
          "command": "apexDoctor.clearRecent",
          "when": "view == apexDoctor.recent",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "apexDoctor.removeRecent",
          "when": "view == apexDoctor.recent && viewItem == apexDoctor.recentEntry",
          "group": "inline"
        }
      ],
      "commandPalette": [
        {
          "command": "apexDoctor.analyze"
        },
        {
          "command": "apexDoctor.fetchLog"
        },
        {
          "command": "apexDoctor.exportMarkdown"
        },
        {
          "command": "apexDoctor.setApiKey"
        },
        {
          "command": "apexDoctor.clearApiKey"
        },
        {
          "command": "apexDoctor.startStream"
        },
        {
          "command": "apexDoctor.stopStream"
        },
        {
          "command": "apexDoctor.compareLogs"
        },
        {
          "command": "apexDoctor.clearRecent"
        },
        {
          "command": "apexDoctor.manageTraceFlags"
        },
        {
          "command": "apexDoctor.refreshCoverage"
        },
        {
          "command": "apexDoctor.toggleCoverage"
        },
        {
          "command": "apexDoctor.queryPlan"
        },
        {
          "command": "apexDoctor.openAnonymousEditor"
        },
        {
          "command": "apexDoctor.runAnonymousApex"
        },
        {
          "command": "apexDoctor.openRecent",
          "when": "false"
        },
        {
          "command": "apexDoctor.removeRecent",
          "when": "false"
        }
      ]
    },
    "configuration": {
      "title": "Apex Doctor",
      "properties": {
        "apexDoctor.provider": {
          "type": "string",
          "enum": [
            "openrouter",
            "anthropic",
            "openai",
            "gemini",
            "einstein"
          ],
          "enumDescriptions": [
            "OpenRouter — free tier available, key starts with sk-or-",
            "Anthropic Claude — paid, key starts with sk-ant-",
            "OpenAI (ChatGPT) — paid, key starts with sk-",
            "Google Gemini — free tier available, key starts with AIza",
            "Salesforce Einstein — runs through your org's Einstein Trust Layer; data never leaves Salesforce. Requires an External Client App (see einsteinDomain / einsteinConsumerKey)."
          ],
          "default": "openrouter",
          "description": "LLM provider. OpenRouter and Gemini have free tiers; Einstein keeps all data inside the Salesforce Trust Layer."
        },
        "apexDoctor.model": {
          "type": "string",
          "default": "",
          "description": "Model name. Leave empty to use the best default for the selected provider: google/gemma-4-31b-it:free (OpenRouter — free, with automatic fallback to other free models), claude-sonnet-4-5 (Anthropic), gpt-4o-mini (OpenAI), gemini-3.5-flash (Gemini), sfdc_ai__DefaultOpenAIGPT4OmniMini (Einstein — use any sfdc_ai__* model your org exposes)."
        },
        "apexDoctor.einsteinDomain": {
          "type": "string",
          "default": "",
          "description": "Salesforce Einstein only. Your My Domain host, e.g. mycompany.my.salesforce.com (no https://). Used for the OAuth token exchange and the Models API call."
        },
        "apexDoctor.einsteinConsumerKey": {
          "type": "string",
          "default": "",
          "description": "Salesforce Einstein only. The consumer key (client_id) of your External Client App that has the sfap_api OAuth scope. Store the matching consumer secret via 'Apex Doctor: Set LLM API Key'."
        },
        "apexDoctor.maxTokens": {
          "type": "number",
          "default": 1500,
          "description": "Maximum tokens for AI response."
        },
        "apexDoctor.soqlInLoopThreshold": {
          "type": "number",
          "default": 5,
          "description": "Flag SOQL-in-loop when the same query repeats at least this many times."
        },
        "apexDoctor.largeQueryThreshold": {
          "type": "number",
          "default": 1000,
          "description": "Flag a SOQL query as 'large' when it returns at least this many rows."
        },
        "apexDoctor.streamDebugLevel": {
          "type": "string",
          "default": "",
          "description": "Optional debug level to pass to 'sf apex tail log --debug-level'. Leave empty to stream with default trace flag."
        },
        "apexDoctor.slowSoqlThresholdMs": {
          "type": "number",
          "default": 1000,
          "description": "Flag a SOQL query as 'slow' when its duration is at least this many milliseconds."
        },
        "apexDoctor.slowMethodThresholdMs": {
          "type": "number",
          "default": 0,
          "description": "Flag any method slower than this many milliseconds. Set to 0 to disable."
        },
        "apexDoctor.flagSoqlOnObjects": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          },
          "description": "List of sObject names (e.g. [\"Account\", \"Opportunity\"]) — Apex Doctor warns whenever a SOQL query touches one of these objects. Useful for objects with strict perf budgets."
        },
        "apexDoctor.enableInlineDiagnostics": {
          "type": "boolean",
          "default": true,
          "description": "Show issues as red squiggles directly in the open log file (Problems pane integration)."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.116.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}
